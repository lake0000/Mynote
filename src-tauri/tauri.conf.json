{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mynote",
  "version": "0.1.0",
  "identifier": "local.mynote.desktop",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mynote 私人日记",
        "width": 1220,
        "height": 820,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
